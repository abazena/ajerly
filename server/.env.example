NODE_ENV=development
PORT=4000

# MongoDB — replica set required for transactions.
# Local dev: run mongod with --replSet rs0 and rs.initiate().
MONGODB_URI=mongodb://127.0.0.1:27017/ajerly?replicaSet=rs0

# JWT — separate secrets per realm (hard wall).
TENANT_JWT_SECRET=replace-with-long-random-tenant-secret
OPERATOR_JWT_SECRET=replace-with-long-random-operator-secret
TENANT_JWT_TTL=30d
OPERATOR_JWT_TTL=7d

# bcrypt
BCRYPT_ROUNDS=12

# Storage driver: "local" or "s3".
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# S3 (only when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Platform defaults (also stored in PlatformSettings — env is the bootstrap fallback).
TRIAL_DAYS=14
PRICE_PER_MONTH_LYD=100

# CORS — comma-separated origins for the Next.js client.
CORS_ORIGINS=http://localhost:3000
